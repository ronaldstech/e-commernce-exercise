<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home</title>
    <style>
        .sideBar{
            position: fixed;
            margin: 0;
            height: 100vh;
            border: 1px solid grey;
            width: 20%;
            padding: 1rem;
        }
        *{
            box-sizing: border-box;
        }
        .mainContent{
            border: 1px solid grey;
            margin-left: 300px;
        }
        .catBtn{
            display: block;
            padding: 0.8rem;
            text-decoration: none;
            background-color: blue;
            color: white;
            margin-bottom: 4px;
            border-radius: 6px;
        }
        .cards{
            display: flex;
            flex-wrap: wrap;
            gap: 16px;
            padding: 16px;
        }
        .card{
            flex: 0 0 220px;
            padding: 12px;
            border: 1px solid rgb(230, 224, 224);
        }
        .vBtn{
            text-decoration: none;
            background-color: blue;
            color: white;
            width: 100%;
            padding: 0.6rem;
            border-radius: 6px;
        }
        .cartBtn{
            padding: 0.8rem;
            color: green;
            border: 1px solid green;
            border-radius: 6px;
            display: block;
            width: 100%;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="sideBar">
            <h2>Categories</h2>
            <a href="#">All Products</a>
            <%
                categories.forEach((c)=> {
                    %>
                    <a href="#" class="catBtn"><%= c.name %></a>
                    <%
                })
            %>
            <a href="/product-cart" class="cartBtn">Cart</a>
            <a href="/orders" class="cartBtn" style="margin-top:8px; color:blue; border-color:blue;">View Orders</a>
            <a href="/add-product">Add new product</a>
        </div>
        <div class="mainContent">
            <div class="cards">
                <%
                products.forEach((p) => {
                    %>
                        <div class="card">
                            <img src="http://localhost:4000<%=p.image %>" alt="<%= p.title %>" width="100"><br>
                            <p><%= p.title %></p>
                            <p><%= p.price %></p>
                            <a href="/product-detail?id=<%= p.id %>" class="vBtn">View Details</a>
                        </div>
                    <%
                })%>
            </div>
            <%= user.username %> <%= user.email %> <%= user.id %>
        </div>
    </div>
</body>
</html>