<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Orders</title>
    <style>
        body{
            background:#eee;
            font-family: Arial;
        }
        .container{
            width:60%;
            margin:auto;
        }
        .order{
            background:white;
            padding:1rem;
            margin-bottom:20px;
            border-radius:10px;
        }
        .order-header{
            display:flex;
            justify-content:space-between;
            margin-bottom:10px;
        }
        .item{
            display:flex;
            gap:10px;
            border-top:1px solid #ddd;
            padding:10px 0;
        }
        .item img{
            width:80px;
            border-radius:8px;
        }
        .details{
            flex:1;
        }
        .price{
            color:blue;
            font-weight:bold;
        }
    </style>
</head>
<body>

<div class="container">
    <h2>My Orders</h2>

    <% if(orders.length === 0){ %>
        <p>No orders yet.</p>
    <% } %>

    <% orders.forEach(order => { %>
        <div class="order">
            <div class="order-header">
                <span><strong>Order ID:</strong> <%= order.id %></span>
                <span><strong>Date:</strong> <%= new Date(order.createdAt).toLocaleString() %></span>
            </div>

            <% 
                let total = 0;
                order.items.forEach(item => {
                    total += item.quantity * item.price;
                });
            %>

            <% order.items.forEach(item => { %>
                <div class="item">
                    <img src="http://localhost:4000<%= item.product?.image %>" />
                    <div class="details">
                        <h4><%= item.product?.title || "Product" %></h4>
                        <p>Qty: <%= item.quantity %></p>
                        <p class="price">$<%= item.price %></p>
                    </div>
                </div>
            <% }) %>

            <div style="text-align:right; margin-top:10px;">
                <strong>Total: $<%= total.toFixed(2) %></strong>
            </div>
        </div>
    <% }) %>

</div>

</body>
</html>