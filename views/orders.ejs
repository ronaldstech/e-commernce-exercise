<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Orders</title>
    <style>
        body{
            background:#eee;
            font-family: Arial;
        }
        .container{
            width:60%;
            margin:auto;
        }
        .order{
            background:white;
            padding:1rem;
            margin-bottom:20px;
            border-radius:10px;
        }
        .order-header{
            display:flex;
            justify-content:space-between;
            margin-bottom:10px;
        }
        .item{
            display:flex;
            gap:10px;
            border-top:1px solid #ddd;
            padding:10px 0;
        }
        .item img{
            width:80px;
            border-radius:8px;
        }
        .details{
            flex:1;
        }
        .price{
            color:blue;
            font-weight:bold;
        }
        .totals{
            display: flex;
            justify-content: space-between;
            padding: 1rem;
            background-color: white;
            border-radius: 10px 15px;
        }
        .figure span{
            color: blue;
        }
        td{
            padding:8px; 
            border:1px solid #ddd;
        }
    </style>
</head>
<body>

<div class="container">

    <h2>My Orders</h2>

    <% if(orders.length === 0){ %>
        <p>No orders yet.</p>
    <% } else { %>
        <table style="width:100%; background:white; border-radius:8px; margin-bottom:2rem; border-collapse:collapse;">
            <thead>
                <tr style="background:#f0f0f0;">
                    <th style="padding:8px; border:1px solid #ddd;">Order ID</th>
                    <th style="padding:8px; border:1px solid #ddd;">Username</th>
                    <th style="padding:8px; border:1px solid #ddd;">Email</th>
                    <th style="padding:8px; border:1px solid #ddd;">Amount</th>
                </tr>
            </thead>
            <tbody>
                <% orders.forEach(order => { %>
                    <tr>
                        <td><%= order.id %></td>
                        <td><%= order.user?.username || order.username || '' %></td>
                        <td><%= order.user?.email || '' %></td>
                        <td style="padding:8px; border:1px solid #ddd; color:blue; font-weight:bold;">$
                            <%= order.total.toFixed(2) %>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    <% } %>

    <div class="totals">
        <div class="totalOrders">
            <h3>Total Orders: <%= orders.length %></h3>
        </div>
        <div class="figure">
            <h3>Total Revenue: <span>$ <%= total %></span></h3>
        </div>
    </div>

</div>

</body>
</html>